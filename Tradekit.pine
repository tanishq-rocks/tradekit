//@version=6
indicator("TradeKit", shorttitle="TradeKit", overlay=true, max_lines_count=500)

//==================================================
// FEATURES
//==================================================
groupFeatures = "Features"

enableMA1       = input.bool(true,  "Enable MA 1", group=groupFeatures)
enableMA2       = input.bool(true,  "Enable MA 2", group=groupFeatures)
enableMA3       = input.bool(true,  "Enable MA 3", group=groupFeatures)
enableMA4       = input.bool(true,  "Enable MA 4", group=groupFeatures)
enableInsideBar = input.bool(true,  "Enable Inside Bar", group=groupFeatures)
enableBB = input.bool(true, "Enable Bollinger Bands", group=groupFeatures)
enableDHL = input.bool(true, "Enable Daily High/Low", group=groupFeatures)
enablePDHL      = input.bool(true,  "Enable Previous Day High/Low", group=groupFeatures)
enablePWHL      = input.bool(false, "Enable Previous Week High/Low", group=groupFeatures)
enablePMHL      = input.bool(false, "Enable Previous Month High/Low", group=groupFeatures)
enableVWAP      = input.bool(false, "Enable VWAP", group=groupFeatures)

//==================================================
// SOURCE
//==================================================
src = input.source(close, "EMA Source")

//==================================================
// SHARED FUNCTIONS
//==================================================
// MA Function
ma(source, length, _type) =>
    switch _type
        "SMA"         => ta.sma(source, length)
        "EMA"         => ta.ema(source, length)
        "SMMA (RMA)"  => ta.rma(source, length)
        "WMA"         => ta.wma(source, length)
        "VWMA"        => ta.vwma(source, length)

//==================================================
// MA 1
//==================================================
groupMA1 = "MA 1"

len1   = input.int(9, "Length", minval=1, group=groupMA1)
type1  = input.string("EMA", "Type",
     options=["SMA", "EMA", "SMMA (RMA)", "WMA", "VWMA"],
     group=groupMA1)
color1 = input.color(color.blue, "Color", group=groupMA1)

//==================================================
// MA 2
//==================================================
groupMA2 = "MA 2"

len2   = input.int(13, "Length", minval=1, group=groupMA2)
type2  = input.string("EMA", "Type",
     options=["SMA", "EMA", "SMMA (RMA)", "WMA", "VWMA"],
     group=groupMA2)
color2 = input.color(color.aqua, "Color", group=groupMA2)

//==================================================
// MA 3
//==================================================
groupMA3 = "MA 3"

len3   = input.int(50, "Length", minval=1, group=groupMA3)
type3  = input.string("EMA", "Type",
     options=["SMA", "EMA", "SMMA (RMA)", "WMA", "VWMA"],
     group=groupMA3)
color3 = input.color(color.green, "Color", group=groupMA3)

//==================================================
// MA 4
//==================================================
groupMA4 = "MA 4"

len4   = input.int(200, "Length", minval=1, group=groupMA4)
type4  = input.string("EMA", "Type",
     options=["SMA", "EMA", "SMMA (RMA)", "WMA", "VWMA"],
     group=groupMA4)
color4 = input.color(color.red, "Color", group=groupMA4)

//==================================================
// MA CALCULATIONS
//==================================================
ma1 = ma(src, len1, type1)
ma2 = ma(src, len2, type2)
ma3 = ma(src, len3, type3)
ma4 = ma(src, len4, type4)

//==================================================
// MA PLOTS
//==================================================
plot(enableMA1 ? ma1 : na, title="MA 1", color=color1, linewidth=1)
plot(enableMA2 ? ma2 : na, title="MA 2", color=color2, linewidth=1)
plot(enableMA3 ? ma3 : na, title="MA 3", color=color3, linewidth=1)
plot(enableMA4 ? ma4 : na, title="MA 4", color=color4, linewidth=1)

//==================================================
// INSIDE BAR SETTINGS
//==================================================
groupIB = "Inside Bar"

insideColor = input.color(color.white, "Inside Bar Color", group=groupIB)
showIBLabel = input.bool(false, "Show IB Label", group=groupIB)

//==================================================
// INSIDE BAR LOGIC
//==================================================
insideBar = enableInsideBar and barstate.isconfirmed and high < high[1] and low > low[1]

// Color candle
barcolor(insideBar ? insideColor : na)

// Label
plotshape(
     showIBLabel and insideBar,
     title="Inside Bar",
     style=shape.triangleup,
     location=location.belowbar,
     color=insideColor,
     size=size.tiny,
     text="IB"
)

//==================================================
// ALERT
//==================================================
alertcondition(enableInsideBar and insideBar,
     title="Inside Bar",
     message="Inside Bar detected")

//==================================================
// BOLLINGER BANDS
//==================================================
// Adapted from TradingView's built-in Bollinger Bands indicator (open-source, Mozilla Public License 2.0).
groupBB = "Bollinger Bands"

TT_LENGTH  = "The time period to be used in calculating the MA which creates the base for the Upper and Lower Bands."
TT_MA_TYPE = "Determines the type of Moving Average that is applied to the basis plot line."
TT_SOURCE  = "Determines what data from each bar will be used in calculations."
TT_MULT    = "The number of Standard Deviations away from the MA that the Upper and Lower Bands should be."

bbLength = input.int(20, "Length", minval=1, tooltip=TT_LENGTH, group=groupBB)
bbMAType = input.string("EMA", "Basis MA Type",
     options=["SMA", "EMA", "SMMA (RMA)", "WMA", "VWMA"],
     tooltip=TT_MA_TYPE,
     group=groupBB)

bbSrc = input.source(close, "Source", tooltip=TT_SOURCE, group=groupBB)

bbMult = input.float(2.0, "StdDev",
     minval=0.001,
     maxval=50,
     tooltip=TT_MULT,
     group=groupBB)

bbOffset = input.int(0, "Offset",
     minval=-500,
     maxval=500,
     display=display.none,
     group=groupBB)

// BB Calculation
basis = ma(bbSrc, bbLength, bbMAType)
dev = bbMult * ta.stdev(bbSrc, bbLength)
upper = basis + dev
lower = basis - dev

// BB Plots
pBasis = plot(enableBB ? basis : na, "BB Basis", color=#2962FF, offset=bbOffset)
pUpper = plot(enableBB ? upper : na, "BB Upper", color=#F23645, offset=bbOffset)
pLower = plot(enableBB ? lower : na, "BB Lower", color=#089981, offset=bbOffset)

fill(pUpper, pLower,
     title="BB Fill",
     color=enableBB ? color.rgb(33,150,243,95) : na)

//==================================================
// SETTINGS
//==================================================
groupDHL = "Daily High / Low"

highColor = input.color(color.lime, "High Color", group=groupDHL)
lowColor  = input.color(color.red, "Low Color", group=groupDHL)

lineWidth = input.int(2, "Line Width", minval=1, maxval=5, group=groupDHL)

lineStyleInput = input.string(
     "Dotted",
     "Line Style",
     options = ["Solid", "Dashed", "Dotted"],
     group = groupDHL)

//==================================================
// LINE STYLE
//==================================================
lineStyle =
     lineStyleInput == "Solid"  ? line.style_solid :
     lineStyleInput == "Dashed" ? line.style_dashed :
                                  line.style_dotted

//==================================================
// VARIABLES
//==================================================
newDay = timeframe.change("D")

var float dayHigh = na
var float dayLow = na
var int dayStart = na

var line highLine = na
var line lowLine = na

var line[] highLines = array.new_line()
var line[] lowLines = array.new_line()

//==================================================
// DRAW DAILY HIGH / LOW
//==================================================
if enableDHL

    if newDay

        // Finish previous day's lines
        if not na(highLine)
            line.set_xy2(highLine, bar_index - 1, dayHigh)

        if not na(lowLine)
            line.set_xy2(lowLine, bar_index - 1, dayLow)

        // Start new day
        dayHigh := high
        dayLow := low
        dayStart := bar_index

        highLine := line.new(
             dayStart,
             dayHigh,
             dayStart,
             dayHigh,
             color = highColor,
             width = lineWidth,
             style = lineStyle)

        lowLine := line.new(
             dayStart,
             dayLow,
             dayStart,
             dayLow,
             color = lowColor,
             width = lineWidth,
             style = lineStyle)

        array.push(highLines, highLine)
        array.push(lowLines, lowLine)

    else

        dayHigh := math.max(dayHigh, high)
        dayLow := math.min(dayLow, low)

        line.set_xy1(highLine, dayStart, dayHigh)
        line.set_xy2(highLine, bar_index, dayHigh)

        line.set_xy1(lowLine, dayStart, dayLow)
        line.set_xy2(lowLine, bar_index, dayLow)

        // Update style dynamically
        line.set_color(highLine, highColor)
        line.set_color(lowLine, lowColor)

        line.set_width(highLine, lineWidth)
        line.set_width(lowLine, lineWidth)

        line.set_style(highLine, lineStyle)
        line.set_style(lowLine, lineStyle)

//==================================================
// PREVIOUS DAY HIGH / LOW SETTINGS
//==================================================
groupPDHL = "Previous Day High/Low"

pdHighColor      = input.color(color.orange, "High Color", group=groupPDHL)
pdLowColor       = input.color(color.orange, "Low Color", group=groupPDHL)
pdLineWidth      = input.int(1, "Line Width", minval=1, maxval=5, group=groupPDHL)
pdLineStyleInput = input.string(
     "Dashed",
     "Line Style",
     options = ["Solid", "Dashed", "Dotted"],
     group = groupPDHL)

pdLineStyle =
     pdLineStyleInput == "Solid"  ? line.style_solid :
     pdLineStyleInput == "Dashed" ? line.style_dashed :
                                     line.style_dotted

//==================================================
// PREVIOUS DAY HIGH / LOW LOGIC
//==================================================
[pdHigh, pdLow] = request.security(syminfo.tickerid, "D", [high[1], low[1]], lookahead=barmerge.lookahead_on)

var line pdHighLine = na
var line pdLowLine = na

if enablePDHL

    if newDay

        if not na(pdHigh)
            pdHighLine := line.new(bar_index, pdHigh, bar_index, pdHigh, color=pdHighColor, width=pdLineWidth, style=pdLineStyle)
        else
            pdHighLine := na

        if not na(pdLow)
            pdLowLine := line.new(bar_index, pdLow, bar_index, pdLow, color=pdLowColor, width=pdLineWidth, style=pdLineStyle)
        else
            pdLowLine := na

    else

        if not na(pdHighLine) and not na(pdHigh)
            line.set_xy2(pdHighLine, bar_index, pdHigh)
            line.set_color(pdHighLine, pdHighColor)
            line.set_width(pdHighLine, pdLineWidth)
            line.set_style(pdHighLine, pdLineStyle)

        if not na(pdLowLine) and not na(pdLow)
            line.set_xy2(pdLowLine, bar_index, pdLow)
            line.set_color(pdLowLine, pdLowColor)
            line.set_width(pdLowLine, pdLineWidth)
            line.set_style(pdLowLine, pdLineStyle)

//==================================================
// PREVIOUS WEEK HIGH / LOW SETTINGS
//==================================================
groupPWHL = "Previous Week High/Low"

pwHighColor      = input.color(color.purple, "High Color", group=groupPWHL)
pwLowColor       = input.color(color.purple, "Low Color", group=groupPWHL)
pwLineWidth      = input.int(1, "Line Width", minval=1, maxval=5, group=groupPWHL)
pwLineStyleInput = input.string(
     "Dashed",
     "Line Style",
     options = ["Solid", "Dashed", "Dotted"],
     group = groupPWHL)

pwLineStyle =
     pwLineStyleInput == "Solid"  ? line.style_solid :
     pwLineStyleInput == "Dashed" ? line.style_dashed :
                                     line.style_dotted

//==================================================
// PREVIOUS WEEK HIGH / LOW LOGIC
//==================================================
newWeek = timeframe.change("W")

[pwHigh, pwLow] = request.security(syminfo.tickerid, "W", [high[1], low[1]], lookahead=barmerge.lookahead_on)

var line pwHighLine = na
var line pwLowLine = na

if enablePWHL

    if newWeek

        if not na(pwHigh)
            pwHighLine := line.new(bar_index, pwHigh, bar_index, pwHigh, color=pwHighColor, width=pwLineWidth, style=pwLineStyle)
        else
            pwHighLine := na

        if not na(pwLow)
            pwLowLine := line.new(bar_index, pwLow, bar_index, pwLow, color=pwLowColor, width=pwLineWidth, style=pwLineStyle)
        else
            pwLowLine := na

    else

        if not na(pwHighLine) and not na(pwHigh)
            line.set_xy2(pwHighLine, bar_index, pwHigh)
            line.set_color(pwHighLine, pwHighColor)
            line.set_width(pwHighLine, pwLineWidth)
            line.set_style(pwHighLine, pwLineStyle)

        if not na(pwLowLine) and not na(pwLow)
            line.set_xy2(pwLowLine, bar_index, pwLow)
            line.set_color(pwLowLine, pwLowColor)
            line.set_width(pwLowLine, pwLineWidth)
            line.set_style(pwLowLine, pwLineStyle)

//==================================================
// PREVIOUS MONTH HIGH / LOW SETTINGS
//==================================================
groupPMHL = "Previous Month High/Low"

pmHighColor      = input.color(color.teal, "High Color", group=groupPMHL)
pmLowColor       = input.color(color.teal, "Low Color", group=groupPMHL)
pmLineWidth      = input.int(1, "Line Width", minval=1, maxval=5, group=groupPMHL)
pmLineStyleInput = input.string(
     "Dashed",
     "Line Style",
     options = ["Solid", "Dashed", "Dotted"],
     group = groupPMHL)

pmLineStyle =
     pmLineStyleInput == "Solid"  ? line.style_solid :
     pmLineStyleInput == "Dashed" ? line.style_dashed :
                                     line.style_dotted

//==================================================
// PREVIOUS MONTH HIGH / LOW LOGIC
//==================================================
newMonth = timeframe.change("M")

[pmHigh, pmLow] = request.security(syminfo.tickerid, "M", [high[1], low[1]], lookahead=barmerge.lookahead_on)

var line pmHighLine = na
var line pmLowLine = na

if enablePMHL

    if newMonth

        if not na(pmHigh)
            pmHighLine := line.new(bar_index, pmHigh, bar_index, pmHigh, color=pmHighColor, width=pmLineWidth, style=pmLineStyle)
        else
            pmHighLine := na

        if not na(pmLow)
            pmLowLine := line.new(bar_index, pmLow, bar_index, pmLow, color=pmLowColor, width=pmLineWidth, style=pmLineStyle)
        else
            pmLowLine := na

    else

        if not na(pmHighLine) and not na(pmHigh)
            line.set_xy2(pmHighLine, bar_index, pmHigh)
            line.set_color(pmHighLine, pmHighColor)
            line.set_width(pmHighLine, pmLineWidth)
            line.set_style(pmHighLine, pmLineStyle)

        if not na(pmLowLine) and not na(pmLow)
            line.set_xy2(pmLowLine, bar_index, pmLow)
            line.set_color(pmLowLine, pmLowColor)
            line.set_width(pmLowLine, pmLineWidth)
            line.set_style(pmLowLine, pmLineStyle)

//==================================================
// VWAP
//==================================================
groupVWAP = "VWAP"

vwapColor     = input.color(color.yellow, "VWAP Color", group=groupVWAP)
vwapShowBands = input.bool(false, "Show Bands", group=groupVWAP)
vwapBandsMult = input.float(2.0, "Bands StdDev",
     minval=0.001,
     maxval=50,
     group=groupVWAP)

// VWAP Calculation
[vwapValue, vwapUpper, vwapLower] = ta.vwap(hlc3, newDay, vwapBandsMult)

// VWAP Plots
plot(enableVWAP ? vwapValue : na, title="VWAP", color=vwapColor, linewidth=2)

pVWAPUpper = plot(enableVWAP and vwapShowBands ? vwapUpper : na, title="VWAP Upper Band", color=vwapColor)
pVWAPLower = plot(enableVWAP and vwapShowBands ? vwapLower : na, title="VWAP Lower Band", color=vwapColor)

fill(pVWAPUpper, pVWAPLower,
     title="VWAP Band Fill",
     color=enableVWAP and vwapShowBands ? color.new(vwapColor, 90) : na)