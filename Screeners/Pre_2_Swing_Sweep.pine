 barstate.isconfirmed

short_condition_2 = 
 zz_2 < zz_3 and
 zz_2 < zz_4 and
 zz_2 < zz_6 and
 zz_2 < zz_7 and

 zz_3 < zz_5 and
 zz_3 > zz_4 and
