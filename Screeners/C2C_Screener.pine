    'Nifty Metal' => page_niftymetal(i_page_niftymetal)
    'Nifty Pharma' => page_niftypharma(i_page_niftypharma)
    'Nifty Realty' => page_niftyrealty(i_page_niftyrealty)
    => i_symbols

//_____________________________ Preset Index List Pages End

//_____________________________ Get Symbols for Screener Start

feed(back) =>                                             // extract tickerid and decrement list of ticker IDs
    loop  = back                                          // declare string variable to hold content list
    getT  = string(na)                                    // declare string variable to hold tickerid
    if str.length(loop) == 0                              // if list is empty
        getT := string(na)                                // assign na to tickerid variable
        loop := string(na)                                // assign na to list of ticker Ids variable
    else                                                  // else extract first tickerid
        getP  = nz(str.pos(loop, ','), str.length(loop))  // get position of first comma or last character
        getT := str.substring(loop, 0, getP)              // get tickerid in first position of list
        loop := str.replace(loop, getT + ',', '')         // clear tickerid + delimiter character from list
    [getT, loop]                                          // return tickerid in first position & truncated list

[tid_001, out_001] = feed(effective_symbols), [tid_002, out_002] = feed(out_001), [tid_003, out_003] = feed(out_002), [tid_004, out_004] = feed(out_003), [tid_005, out_005] = feed(out_004), [tid_006, out_006] = feed(out_005), [tid_007, out_007] = feed(out_006), [tid_008, out_008] = feed(out_007), [tid_009, out_009] = feed(out_008), [tid_010, out_010] = feed(out_009), [tid_011, out_011] = feed(out_010), [tid_012, out_012] = feed(out_011), [tid_013, out_013] = feed(out_012), [tid_014, out_014] = feed(out_013), [tid_015, out_015] = feed(out_014), [tid_016, out_016] = feed(out_015), [tid_017, out_017] = feed(out_016), [tid_018, out_018] = feed(out_017), [tid_019, out_019] = feed(out_018), [tid_020, out_020] = feed(out_019), [tid_021, out_021] = feed(out_020), [tid_022, out_022] = feed(out_021), [tid_023, out_023] = feed(out_022), [tid_024, out_024] = feed(out_023), [tid_025, out_025] = feed(out_024), [tid_026, out_026] = feed(out_025), [tid_027, out_027] = feed(out_026), [tid_028, out_028] = feed(out_027), [tid_029, out_029] = feed(out_028), [tid_030, out_030] = feed(out_029), [tid_031, out_031] = feed(out_030), [tid_032, out_032] = feed(out_031), [tid_033, out_033] = feed(out_032), [tid_034, out_034] = feed(out_033), [tid_035, out_035] = feed(out_034), [tid_036, out_036] = feed(out_035), [tid_037, out_037] = feed(out_036), [tid_038, out_038] = feed(out_037), [tid_039, out_039] = feed(out_038), [tid_040, out_040] = feed(out_039)

//_____________________________ Get Symbols for Screener End

//_____________________________ Symbol Count & Limit Warning Start

// request.security() is hard-capped at 40 calls per script, so only the first
// 40 symbols in Notes ever get scanned. Detect any leftover text past the
// 40th symbol (still sitting in out_040) to warn the user how many to remove.
allTids = array.from(tid_001, tid_002, tid_003, tid_004, tid_005, tid_006, tid_007, tid_008, tid_009, tid_010, tid_011, tid_012, tid_013, tid_014, tid_015, tid_016, tid_017, tid_018, tid_019, tid_020, tid_021, tid_022, tid_023, tid_024, tid_025, tid_026, tid_027, tid_028, tid_029, tid_030, tid_031, tid_032, tid_033, tid_034, tid_035, tid_036, tid_037, tid_038, tid_039, tid_040)

validCount = 0
for i = 0 to array.size(allTids) - 1
    if not na(array.get(allTids, i))
        validCount += 1

// Note: when Notes has exactly 40 symbols, the final feed() call has no
// trailing comma to strip, so out_040 ends up equal to tid_040 itself rather
// than empty — exclude that self-residue case so 40 symbols isn't
// miscounted as 41.
extraCount = 0
if not na(out_040) and str.length(out_040) > 0 and out_040 != tid_040
    extraCount := array.size(str.split(out_040, ","))

totalEntered = validCount + extraCount

//_____________________________ Symbol Count & Limit Warning End

//_____________________________ Screener Start

// Direction toggles derived from the Direction input
bool want_bull = i_direction != 'Bearish'
bool want_bear = i_direction != 'Bullish'

// Function to extract symbol name from "EXCHANGE:SYMBOL"
symbol(s) =>
    array.get(str.split(s, ":"), 1)

// Function to format time
format_time(x) =>
    timezone = syminfo.timezone
    timeframe.isintraday ? str.format_time(x, "HH:mm  dd-MM-yyyy", timezone) : str.format_time(x, "dd-MM-yyyy", timezone)

// C2C Inside Bar scan, evaluated inside the requested symbol's own context.
// Rolls a window of the last `n` confirmed bars: keeps every match whose
// bar is still within that window, dropping ones that age out.
scan_symbol(int n, bool wantBull, bool wantBear) =>
    var array<float> times = array.new_float()
    var array<float> prices = array.new_float()
    var array<int> signals = array.new_int()
    var array<int> bars = array.new_int()

    if barstate.isconfirmed
        prevGreen = close[1] > open[1]
        prevRed   = close[1] < open[1]
        isInsider = high < high[1] and low > low[1]
        bullish   = isInsider and prevGreen and close[1] < close
        bearish   = isInsider and prevRed and close[1] > close

        if (bullish and wantBull) or (bearish and wantBear)
            array.push(times, time)
            array.push(prices, close)
            array.push(signals, bullish ? 1 : -1)
            array.push(bars, bar_index)

        while array.size(bars) > 0
            if bar_index - array.get(bars, 0) > n
                array.shift(bars)
                array.shift(times)
                array.shift(prices)
                array.shift(signals)
            else
                break

    [times, prices, signals]

// Screener function: request the C2C scan for one symbol, at the chart's own timeframe
screener(s) =>
    sym = ticker.modify(s, syminfo.session)
    [times, prices, signals] = request.security(sym, timeframe.period, scan_symbol(i_lookback, want_bull, want_bear))
    [times, prices, signals]

[t_001, p_001, s_001] = screener(tid_001), [t_002, p_002, s_002] = screener(tid_002), [t_003, p_003, s_003] = screener(tid_003), [t_004, p_004, s_004] = screener(tid_004), [t_005, p_005, s_005] = screener(tid_005), [t_006, p_006, s_006] = screener(tid_006), [t_007, p_007, s_007] = screener(tid_007), [t_008, p_008, s_008] = screener(tid_008), [t_009, p_009, s_009] = screener(tid_009), [t_010, p_010, s_010] = screener(tid_010), [t_011, p_011, s_011] = screener(tid_011), [t_012, p_012, s_012] = screener(tid_012), [t_013, p_013, s_013] = screener(tid_013), [t_014, p_014, s_014] = screener(tid_014), [t_015, p_015, s_015] = screener(tid_015), [t_016, p_016, s_016] = screener(tid_016), [t_017, p_017, s_017] = screener(tid_017), [t_018, p_018, s_018] = screener(tid_018), [t_019, p_019, s_019] = screener(tid_019), [t_020, p_020, s_020] = screener(tid_020), [t_021, p_021, s_021] = screener(tid_021), [t_022, p_022, s_022] = screener(tid_022), [t_023, p_023, s_023] = screener(tid_023), [t_024, p_024, s_024] = screener(tid_024), [t_025, p_025, s_025] = screener(tid_025), [t_026, p_026, s_026] = screener(tid_026), [t_027, p_027, s_027] = screener(tid_027), [t_028, p_028, s_028] = screener(tid_028), [t_029, p_029, s_029] = screener(tid_029), [t_030, p_030, s_030] = screener(tid_030), [t_031, p_031, s_031] = screener(tid_031), [t_032, p_032, s_032] = screener(tid_032), [t_033, p_033, s_033] = screener(tid_033), [t_034, p_034, s_034] = screener(tid_034), [t_035, p_035, s_035] = screener(tid_035), [t_036, p_036, s_036] = screener(tid_036), [t_037, p_037, s_037] = screener(tid_037), [t_038, p_038, s_038] = screener(tid_038), [t_039, p_039, s_039] = screener(tid_039), [t_040, p_040, s_040] = screener(tid_040)

// Master matrix: columns = [time, price, signal, symbolId] ; symbol names kept in a parallel lookup array
var matrix<float> mtx = matrix.new<float>(0, 4)
var array<string> symbolNames = array.new_string()

addResults(symName, times, prices, signals) =>
    n = array.size(times)
    if n > 0
        id = array.size(symbolNames)
        array.push(symbolNames, symName)
        matrix.add_row(mtx, 0, array.from(array.get(times, n - 1), array.get(prices, n - 1), float(array.get(signals, n - 1)), float(id)))

// Plot Table
var table tbl = table.new(position=i_tbl_position, columns=3, rows=105, border_width=1)

cell_title(col, row, txt) =>
    table.cell(tbl, col, row, text = txt, text_color = i_txt_color, text_halign=text.align_center, bgcolor = color.new(i_txt_color, 90), text_size=i_tbl_text_size)

cell(col, row, txt, color) =>
    table.cell(tbl, col, row, text = txt, text_color = color, text_halign=text.align_left, bgcolor = color.new(color, 90), text_size=i_tbl_text_size)

cell_warning(col, row, txt) =>
    table.cell(tbl, col, row, text = txt, text_color = color.white, text_halign=text.align_center, bgcolor = color.new(color.red, 15), text_size=i_tbl_text_size)

if barstate.islast
    // Rebuild the matrix fresh each time from the current rolling windows
    mtx := matrix.new<float>(0, 4)
    array.clear(symbolNames)

    addResults(symbol(tid_001), t_001, p_001, s_001), addResults(symbol(tid_002), t_002, p_002, s_002), addResults(symbol(tid_003), t_003, p_003, s_003), addResults(symbol(tid_004), t_004, p_004, s_004), addResults(symbol(tid_005), t_005, p_005, s_005), addResults(symbol(tid_006), t_006, p_006, s_006), addResults(symbol(tid_007), t_007, p_007, s_007), addResults(symbol(tid_008), t_008, p_008, s_008), addResults(symbol(tid_009), t_009, p_009, s_009), addResults(symbol(tid_010), t_010, p_010, s_010), addResults(symbol(tid_011), t_011, p_011, s_011), addResults(symbol(tid_012), t_012, p_012, s_012), addResults(symbol(tid_013), t_013, p_013, s_013), addResults(symbol(tid_014), t_014, p_014, s_014), addResults(symbol(tid_015), t_015, p_015, s_015), addResults(symbol(tid_016), t_016, p_016, s_016), addResults(symbol(tid_017), t_017, p_017, s_017), addResults(symbol(tid_018), t_018, p_018, s_018), addResults(symbol(tid_019), t_019, p_019, s_019), addResults(symbol(tid_020), t_020, p_020, s_020), addResults(symbol(tid_021), t_021, p_021, s_021), addResults(symbol(tid_022), t_022, p_022, s_022), addResults(symbol(tid_023), t_023, p_023, s_023), addResults(symbol(tid_024), t_024, p_024, s_024), addResults(symbol(tid_025), t_025, p_025, s_025), addResults(symbol(tid_026), t_026, p_026, s_026), addResults(symbol(tid_027), t_027, p_027, s_027), addResults(symbol(tid_028), t_028, p_028, s_028), addResults(symbol(tid_029), t_029, p_029, s_029), addResults(symbol(tid_030), t_030, p_030, s_030), addResults(symbol(tid_031), t_031, p_031, s_031), addResults(symbol(tid_032), t_032, p_032, s_032), addResults(symbol(tid_033), t_033, p_033, s_033), addResults(symbol(tid_034), t_034, p_034, s_034), addResults(symbol(tid_035), t_035, p_035, s_035), addResults(symbol(tid_036), t_036, p_036, s_036), addResults(symbol(tid_037), t_037, p_037, s_037), addResults(symbol(tid_038), t_038, p_038, s_038), addResults(symbol(tid_039), t_039, p_039, s_039), addResults(symbol(tid_040), t_040, p_040, s_040)

    // Sort all matches across all symbols by time, descending (most recent first)
    matrix.sort(mtx, 0, order.descending)

    // Trim to the requested number of display rows
    if matrix.rows(mtx) > i_tbl_disp_rows
        while matrix.rows(mtx) > i_tbl_disp_rows
            matrix.remove_row(mtx, matrix.rows(mtx) - 1)

    // Clear existing data in the table
    table.clear(tbl, 0, 0, 2, 104)

    // Row 0: overflow warning banner — only filled in when the active symbol source has more than 40 symbols
    if extraCount > 0
        cell_warning(0, 0, "⚠ " + str.tostring(totalEntered) + " symbols entered — " + str.tostring(extraCount) + " over the 40 limit. Remove " + str.tostring(extraCount) + " symbols.")
        table.merge_cells(table_id=tbl, start_column=0, start_row=0, end_column=2, end_row=0)

    cell_title(0, 1, "C2C Inside Bar Screener")
    table.merge_cells(table_id=tbl, start_column=0, start_row=1, end_column=2, end_row=1)
    cell_title(0, 2, "Symbol")
    cell_title(1, 2, "Date & Time")
    cell_title(2, 2, "Close")

    j = 3
    if matrix.rows(mtx) > 0
        for i = 0 to matrix.rows(mtx) - 1
            signal = matrix.get(mtx, i, 2)
            col = signal == 1 ? i_pos_color : signal == -1 ? i_neg_color : i_txt_color
            symId = int(matrix.get(mtx, i, 3))
            symName = array.get(symbolNames, symId)

            cell(0, j, symName, col)
            cell(1, j, format_time(int(matrix.get(mtx, i, 0))), col)
            cell(2, j, str.tostring(matrix.get(mtx, i, 1)), col)

            j += 1

//_____________________________ Screener End

//_____________________________ Code End
