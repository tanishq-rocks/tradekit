string i_page_nifty200 = input.string(defval='Page 1 (1-40)', title='Nifty 200 — Page', options=['Page 1 (1-40)', 'Page 2 (41-80)', 'Page 3 (81-120)', 'Page 4 (121-160)', 'Page 5 (161-200)'], group=g_lists)
string i_page_nifty500 = input.string(defval='Page 1 (1-40)', title='Nifty 500 — Page', options=['Page 1 (1-40)', 'Page 2 (41-80)', 'Page 3 (81-120)', 'Page 4 (121-160)', 'Page 5 (161-200)', 'Page 6 (201-240)', 'Page 7 (241-280)', 'Page 8 (281-320)', 'Page 9 (321-360)', 'Page 10 (361-400)', 'Page 11 (401-440)', 'Page 12 (441-480)', 'Page 13 (481-500)'], group=g_lists)
